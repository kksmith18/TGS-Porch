# Copy this file to .env.local and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys
# Use test keys (pk_test_ / sk_test_) for development, live keys for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...       # NEVER prefix with NEXT_PUBLIC_ — server only
STRIPE_WEBHOOK_SECRET=whsec_...     # Found in Stripe → Webhooks after adding endpoint

# ── Resend (email) ────────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_...               # Server only — never expose to browser

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://tgsporch.com   # Use http://localhost:3000 for local dev
DAD_EMAIL=contact@tgsporch.com              # Where order notifications are sent
